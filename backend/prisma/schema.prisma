// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rarity {
  COMMON
  RARE
  LEGENDARY
}

enum QuestionType {
  MCQ
  OPEN
}

enum Role {
  USER
  ADMIN
}

model User {
  id            Int                @id @default(autoincrement())
  username      String             @unique
  passwordHash  String
  role          Role               @default(USER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  bodyParts     UserBodyPart[]
  trails        UserTrail[]
  userZones     UserZone[]
}

model ForestFriend {
  id             Int                   @id @default(autoincrement())
  name           String
  imageUrl       String?
  imageFULL      String?
  bodyParts      ForestFriendBodyPart[]
}

model ForestFriendBodyPart {
  id              Int         @id @default(autoincrement())
  name            String
  rarity          Rarity
  imageUrl        String?
  imageUrlZoomed  String?
  forestFriend    ForestFriend   @relation(fields: [forestFriendId], references: [id], onDelete: Cascade)
  forestFriendId  Int
  questions       QuestionBodyPart[]
  userBodyParts   UserBodyPart[]
}

model Trail {
  id          Int           @id @default(autoincrement())
  name        String
  mapUrl      String?
  description String
  photos      TrailPhoto[]
  questions   Question[]
  userTrails  UserTrail[]
}

model TrailPhoto {
  id       Int    @id @default(autoincrement())
  trail    Trail  @relation(fields: [trailId], references: [id], onDelete: Cascade)
  trailId  Int
  photoUrl String
}

model Zone {
  id        Int        @id
  narrative String
  questions Question[]
  userZones UserZone[]
}

model Question {
  id            Int                @id @default(autoincrement())
  trail         Trail              @relation(fields: [trailId], references: [id], onDelete: Cascade)
  trailId       Int
  question      String
  type          QuestionType
  options       Option[]
  bodyParts     QuestionBodyPart[]
  zone          Zone?              @relation(fields: [zoneId], references: [id])
  zoneId        Int?
}

model Option {
  id          Int       @id @default(autoincrement())
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId  Int
  description String
  correct     Boolean
}

model QuestionBodyPart {
  question    Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId  Int
  bodyPart    ForestFriendBodyPart  @relation(fields: [bodyPartId], references: [id], onDelete: Cascade)
  bodyPartId  Int
  @@id([questionId, bodyPartId])
}

model UserBodyPart {
  user      User                  @relation(fields: [userId], references: [id])
  userId    Int
  bodyPart  ForestFriendBodyPart  @relation(fields: [bodyPartId], references: [id])
  bodyPartId Int
  foundAt   DateTime @default(now())
  @@id([userId, bodyPartId])
}

model UserTrail {
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  trail    Trail  @relation(fields: [trailId], references: [id])
  trailId  Int
  startedAt DateTime @default(now())
  @@id([userId, trailId])
}

model UserZone {
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  zone      Zone     @relation(fields: [zoneId], references: [id])
  zoneId    Int
  visitedAt DateTime @default(now())
  @@id([userId, zoneId])
}

