// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rarity {
  COMMON
  RARE
  LEGENDARY
}

enum QuestionType {
  MCQ
  OPEN
}

model User {
  id            Int                @id @default(autoincrement())
  username      String             @unique
  passwordHash String
  bodyParts     UserBodyPart[]
  trails        UserTrail[]
}

model ForestFriend {
  id             Int                   @id @default(autoincrement())
  name           String
  imageUrl       String?
  bodyParts      ForestFriendBodyPart[]
}

model ForestFriendBodyPart {
  id              Int         @id @default(autoincrement())
  name            String
  rarity          Rarity
  imageUrl        String?
  imageUrlZoomed  String?
  forestFriend    ForestFriend   @relation(fields: [forestFriendId], references: [id])
  forestFriendId  Int
  questions       Question[]
  userBodyParts   UserBodyPart[]
  trailBodyParts  TrailBodyPart[]
}

model Trail {
  id          Int           @id @default(autoincrement())
  name        String
  mapUrl      String?
  description String
  photos      TrailPhoto[]
  questions   Question[]
  userTrails  UserTrail[]
  bodyParts   TrailBodyPart[]
}

model TrailPhoto {
  id       Int    @id @default(autoincrement())
  trail    Trail  @relation(fields: [trailId], references: [id])
  trailId  Int
  photoUrl String
}

model Question {
  id            Int                @id @default(autoincrement())
  trail         Trail              @relation(fields: [trailId], references: [id])
  trailId       Int
  bodyPart      ForestFriendBodyPart? @relation(fields: [bodyPartId], references: [id])
  bodyPartId    Int?
  question      String
  type          QuestionType
  options       Option[]
}

model Option {
  id          Int       @id @default(autoincrement())
  question    Question  @relation(fields: [questionId], references: [id])
  questionId  Int
  description String
  correct     Boolean
}

model UserBodyPart {
  user      User                  @relation(fields: [userId], references: [id])
  userId    Int
  bodyPart  ForestFriendBodyPart  @relation(fields: [bodyPartId], references: [id])
  bodyPartId Int
  foundAt   DateTime @default(now())
  @@id([userId, bodyPartId])
}

model UserTrail {
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  trail    Trail  @relation(fields: [trailId], references: [id])
  trailId  Int
  startedAt DateTime @default(now())
  @@id([userId, trailId])
}

model TrailBodyPart {
  trail     Trail                 @relation(fields: [trailId], references: [id])
  trailId   Int
  bodyPart  ForestFriendBodyPart  @relation(fields: [bodyPartId], references: [id])
  bodyPartId Int
  @@id([trailId, bodyPartId])
}
