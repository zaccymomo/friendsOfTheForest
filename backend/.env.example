# Database connection string (PostgreSQL via NeonDB or other provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT secret for authentication tokens (use a secure random 32+ character string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-32-character-string-here

# Server port (default: 4000)
PORT=4000

# Frontend URL for CORS configuration (set in production to Railway frontend URL)
FRONTEND_URL=https://your-frontend-url.railway.app
